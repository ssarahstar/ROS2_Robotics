<?xml version="1.0"?>
<robot name="simple_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========== Materials (RViz 색상용) ========== -->
  <material name="gray"><color rgba="0.6 0.6 0.6 1"/></material>
  <material name="blue"><color rgba="0.2 0.2 0.9 1"/></material>
  <material name="orange"><color rgba="0.95 0.55 0.1 1"/></material>
  
  <!-- ========== base_link ========== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.20 0.20 0.05"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.20 0.20 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.0354167" ixy="0.0" ixz="0.0"
               iyy="0.0354167" iyz="0.0"
               izz="0.0666667"/>
    </inertial>
  </link>

  <!-- ========== link1 (첫 번째 팔) ========== -->
  <link name="link1">
    <visual>
      <!-- 링크 프레임에서 +x 방향으로 길게 보이게 배치 -->
      <origin xyz="0.20 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.40 0.06 0.06"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.20 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.40 0.06 0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.20 0 0.05" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0"
               iyy="0.005" iyz="0.0"
               izz="0.005"/>
    </inertial>
  </link>

  <!-- ========== link1_yaw (중간 더미 링크) ========== -->
  <link name="link1_yaw">
    <!-- Gazebo용: 최소한의 visual/collision/inertial을 넣어서 링크가 제거되지 않게 함 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>


  <!-- ========== link2 (두 번째 팔) ========== -->
  <link name="link2">
    <visual>
      <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.30 0.05 0.05"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.30 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
      <mass value="0.7"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0"
               iyy="0.003" iyz="0.0"
               izz="0.003"/>
    </inertial>
  </link>

  <!-- ========== link3 (세 번째 팔) ========== -->
  <link name="link3">
    <visual>
      <origin xyz="0.12 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.12 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.24 0.04 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.12 0 0.05" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.0015" ixy="0.0" ixz="0.0"
              iyy="0.0015" iyz="0.0"
              izz="0.0015"/>
    </inertial>
  </link>

  <joint name="joint1_z" type="revolute">
    <parent link="base_link"/>
    <child link="link1_yaw"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <joint name="joint1_y" type="revolute">
    <parent link="link1_yaw"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="1.57" effort="10" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.40 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <!-- ========== joint3 (link2 → link3) ========== -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.30 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="8" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.05"/>
  </joint>

  <gazebo reference="base_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- ===================== Gazebo ↔ ros2_control 연결 플러그인 ===================== -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>

      <parameters>/home/deeptree/gazebo_ws/install/simple_arm_description/share/simple_arm_description/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ===================== ros2_control 설정(제어 인터페이스) ===================== -->
  <ros2_control name="SimpleArmSystem" type="system">
    <hardware>
      <!-- Gazebo에서 ros2_control을 사용할 때 표준 시스템 -->
      <plugin>fake_components/GenericSystem</plugin>
    </hardware>

    <!-- joint 이름은 URDF joint 이름과 100% 동일해야 함 -->
    <joint name="joint1_z">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint1_y">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>